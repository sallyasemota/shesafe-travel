# Supabase project URL — the base URL of your project (no trailing path).
# Example: https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (public) key. Project Settings → API → Project API keys.
VITE_SUPABASE_ANON_KEY=

# Anthropic API key — used by api/generate-briefing.ts for AI safety briefings.
ANTHROPIC_API_KEY=

# Firecrawl API key — used to scrape live travel advisories.
# If unset, the briefing falls back to Claude's training data.
FIRECRAWL_API_KEY=
